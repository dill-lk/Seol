{
  "name": "@seol/app",
  "private": true,
  "version": "0.1.0",
  "description": "SEOL – Artificial Feelings companion app",
  "author": "SEOL",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite",
    "build": "vue-tsc --noEmit && electron-vite build",
    "build:web": "vue-tsc --noEmit && vite build",
    "preview": "electron-vite preview",
    "typecheck": "vue-tsc --noEmit",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "io.seol.app",
    "productName": "SEOL",
    "copyright": "Copyright © 2024 SEOL",
    "asar": true,
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist-electron/**",
      "dist/**"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "build/icon.icns",
      "category": "public.app-category.lifestyle"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.5.1",
    "@pixiv/three-vrm-animation": "^3.5.1",
    "@vueuse/core": "^12.7.0",
    "pinia": "^3.0.4",
    "three": "^0.175.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/three": "^0.175.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "electron": "41.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vue-tsc": "^2.2.10"
  }
}

